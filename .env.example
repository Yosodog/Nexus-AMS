APP_NAME="Nexus AMS"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=nexus_ams
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1
REDIS_PULSE_DB=2

SUBS_REDIS_URL=redis://127.0.0.1:6379/3
SUBS_REDIS_CONNECTION=subscriptions
SUBS_REDIS_STREAM=nexus:subscriptions:v1
SUBS_REDIS_GROUP=nexus-ams
SUBS_REDIS_BLOCK_MS=5000
SUBS_REDIS_READ_COUNT=10
SUBS_REDIS_CLAIM_IDLE_MS=60000
SUBS_REDIS_MAX_DELIVERIES=5
SUBS_REDIS_RETRY_DELAY_MS=2000
SUBS_REDIS_DEAD_LETTER_FILE=storage/logs/subscription-stream-dead-letters.jsonl

PULSE_INGEST_DRIVER=redis
PULSE_REDIS_CONNECTION=pulse
PULSE_SLOW_QUERIES_MAX_QUERY_LENGTH=2048
PULSE_CACHE_INTERACTIONS_SAMPLE_RATE=0.05
PULSE_QUEUES_SAMPLE_RATE=0.1
PULSE_SLOW_JOBS_SAMPLE_RATE=0.1
PULSE_SLOW_OUTGOING_REQUESTS_SAMPLE_RATE=0.1
PULSE_SLOW_QUERIES_SAMPLE_RATE=0.1
PULSE_SLOW_REQUESTS_SAMPLE_RATE=0.1
PULSE_USER_JOBS_SAMPLE_RATE=0.1
PULSE_USER_REQUESTS_SAMPLE_RATE=0.1

MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

BACKUP_DESTINATION_DISKS=local
BACKUP_ARCHIVE_PASSWORD=
BACKUP_VERIFY=true
BACKUP_NOTIFICATION_EMAIL=
BACKUP_NOTIFY_ON_SUCCESS=false

VITE_APP_NAME="${APP_NAME}"

PW_API_KEY=
PW_ALLIANCE_ID=
PW_API_MUTATION_KEY=

NEXUS_API_TOKEN=
DISCORD_BOT_KEY=
DISCORD_GUILD_ID=
DISCORD_FINANCE_ACTION_INTENT_TTL_SECONDS=120
DISCORD_WORKFLOW_ACTION_INTENT_TTL_SECONDS=900
